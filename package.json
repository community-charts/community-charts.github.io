      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=24.0"
  },
  "overrides": {
    "@babel/core": "^7.29.6",
    "gray-matter": {
      "js-yaml": "^4.2.0"
    },
    "http-proxy-middleware": "^3.0.6",
    "joi": "^17.13.4",
    "js-yaml": "^4.2.0",
    "serialize-javascript": "^7.0.5",
    "uuid": "^11.1.1"
  }
}
